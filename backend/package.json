{
  "name": "asset-stats-backend",
  "version": "1.0.0",
  "description": "Asset Statistics Backend API",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "_comment_prisma_test": "npx prisma generate --schema prisma/schema.test.prisma && npx prisma db push --schema prisma/schema.test.prisma",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "test": "cross-env NODE_ENV=test vitest run --reporter=verbose",
    "test:watch": "cross-env NODE_ENV=test vitest --reporter=verbose",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:ci": "cross-env NODE_ENV=test vitest run --reporter=junit --outputFile.junit=test-results.xml",
    "test:db:generate": "cross-env DATABASE_URL=file:./tests/test-data.db prisma generate --schema prisma/schema.test.prisma",
    "test:db:push": "cross-env DATABASE_URL=file:./tests/test-data.db prisma db push --schema prisma/schema.test.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
